{
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2023",
    "rootDir": "./",
    "outDir": "./dist",
    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "../../generated/prisma/client": ["./src/generated/prisma/client"],
      "../../generated/prisma/enums": ["./src/generated/prisma/enums"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}